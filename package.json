{
  "name": "ai-assistant",
  "version": "1.0.0",
  "private": true,
  "description": "Personal AI Agent System — local-first, extensible, TypeScript + Ollama",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsx apps/api/src/index.ts",
    "build": "tsc",
    "start": "node dist/apps/api/src/index.js",
    "typecheck": "tsc --noEmit",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "mysql2": "^3.12.0",
    "playwright": "^1.55.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitepress": "^1.6.4"
  }
}
