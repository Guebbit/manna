{
    "name": "@guebbit/manna",
    "version": "0.15.0-alpha",
    "private": true,
    "type": "module",
    "description": "Manna — Personal AI Agent Platform, local-first and extensible (TypeScript + Ollama)",
    "engines": {
        "node": ">=18.0.0"
    },
    "scripts": {
        "dev": "tsx apps/api/index.ts",
        "start": "node dist/apps/api/index.js",
        "db:migrate": "tsx packages/persistence/migrate.ts",
        "ts-check": "tsc --noEmit",
        "build": "npm run typecheck",
        "build-only": "npm run lint",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:eval": "vitest run --config vitest.eval.config.ts",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "lint:openapi": "spectral lint openapi.yaml",
        "lint:openapi:fix": "spectral lint openapi.yaml --format stylish",
        "prettier": "npx prettier .",
        "prettier:check": "npx prettier . --check",
        "prettier:fix": "npx prettier . --write",
        "typecheck": "tsc --noEmit",
        "genapi": "openapi-generator-cli generate -i openapi.yaml -g typescript-fetch -o ./api --additional-properties=supportsES6=true,typescriptThreePlus=true",
        "postinstall": "playwright install chromium",
        "docs:dev": "vitepress dev docs",
        "docs:build": "vitepress build docs",
        "docs:preview": "vitepress preview docs",
        "podman:restart": "podman compose down && podman compose up -d",
        "podman:rebuild": "podman compose down -v && podman compose build --no-cache && podman compose up -d",
        "update:all": "npx npm-check-updates -u",
        "prepare": "husky",
        "complete": "npm run build && npm run test && npm run lint:fix && npm run prettier:fix",
        "complete:check": "npm run build && npm run test && npm run lint && npm run lint:openapi && npm run prettier:check"
    },
    "dependencies": {
        "@langchain/core": "^1.1.39",
        "@langchain/langgraph": "^1.2.8",
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@qdrant/js-client-rest": "^1.15.1",
        "cors": "^2.8.6",
        "express": "^4.21.2",
        "express-rate-limit": "^8.3.2",
        "helmet": "^8.1.0",
        "i18next": "^26.0.4",
        "mongodb": "^7.1.1",
        "multer": "^2.1.1",
        "mysql2": "^3.12.0",
        "neo4j-driver": "^6.0.1",
        "nodemailer": "^8.0.5",
        "pdf-parse": "^2.4.5",
        "pg": "^8.20.0",
        "playwright": "^1.55.1",
        "winston": "^3.19.0",
        "zod": "^3.25.76",
        "zod-to-json-schema": "^3.24.5"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@mermaid-js/mermaid-cli": "^11.12.0",
        "@openapitools/openapi-generator-cli": "^2.31.0",
        "@stoplight/spectral-cli": "^6.15.0",
        "@stoplight/spectral-rulesets": "^1.22.0",
        "@types/cors": "^2.8.19",
        "@types/express": "^4.17.21",
        "@types/multer": "^2.1.0",
        "@types/node": "^22.0.0",
        "@types/nodemailer": "^8.0.0",
        "@types/pg": "^8.20.0",
        "@vitest/coverage-v8": "^4.1.4",
        "ajv": "^8.18.0",
        "eslint": "^10.2.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-oxlint": "^1.60.0",
        "eslint-plugin-unicorn": "^64.0.0",
        "globals": "^17.5.0",
        "husky": "^9.1.7",
        "jiti": "^2.6.1",
        "mermaid": "^11.14.0",
        "prettier": "^3.8.2",
        "tsx": "^4.19.3",
        "typescript": "^5.8.3",
        "typescript-eslint": "^8.58.1",
        "vitepress": "^1.6.4",
        "vitepress-plugin-mermaid": "^2.0.17",
        "vitest": "^4.1.4"
    }
}
