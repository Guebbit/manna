# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for the Podman / Docker Compose stack.
#
# Instructions:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below
#   3. NEVER commit the resulting .env file — it is already in .gitignore
#
# See docs/quickstart.md for a step-by-step first-run guide.
# ─────────────────────────────────────────────────────────────────────────────

# ══ MINIMAL REQUIRED CONFIGURATION ══════════════════════════════════════════
#
# These three variables are all you need for a working first run.
# Every other variable in this file defaults to a sensible value.
#
# Quick start:
#   ollama pull llama3.1:8b
#   ollama pull nomic-embed-text:latest
#   (set the three vars below, then) npm run dev
#
# ─────────────────────────────────────────────────────────────────────────────

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest

# ══ OPTIONAL — override individual profile models ════════════════════════════
#
# All three agent profiles (fast / reasoning / code) fall back to OLLAMA_MODEL
# when their profile-specific variable is not set.  Configure these only when
# you want to dedicate separate models to each reasoning style.
#
# AGENT_MODEL_FAST=llama3.1:8b
# AGENT_MODEL_REASONING=deepseek-r1:32b
# AGENT_MODEL_CODE=qwen2.5-coder:32b

# ════════════════════════════════════════════════════════════════════════════
# The rest of this file is optional configuration.
# ════════════════════════════════════════════════════════════════════════════

# Your Linux username (used to mount the shared ~/.ollama model cache in Docker)
LINUX_USERNAME=your-linux-username

# ── Ollama runtime constraints ──
# Force only ONE model loaded at a time — critical for 24 GB VRAM (RTX 4090)
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=1
OLLAMA_PORT=11434

# ── Agent profile fine-tuning (sampling parameters) ──
# Note: TOP_K and NUM_CTX must be whole numbers (no decimals).
AGENT_MODEL_FAST_TEMPERATURE=0.3
AGENT_MODEL_FAST_TOP_P=0.85
AGENT_MODEL_FAST_TOP_K=30
AGENT_MODEL_FAST_NUM_CTX=4096
AGENT_MODEL_FAST_REPEAT_PENALTY=1.2

AGENT_MODEL_CODE_TEMPERATURE=0.2
AGENT_MODEL_CODE_TOP_P=0.8
AGENT_MODEL_CODE_TOP_K=20
AGENT_MODEL_CODE_NUM_CTX=8192
AGENT_MODEL_CODE_REPEAT_PENALTY=1.3

AGENT_MODEL_REASONING_TEMPERATURE=0.2
AGENT_MODEL_REASONING_TOP_P=0.8
AGENT_MODEL_REASONING_TOP_K=20
AGENT_MODEL_REASONING_NUM_CTX=8192
AGENT_MODEL_REASONING_REPEAT_PENALTY=1.3

# ── Operating mode (low-spec / standard / high-trust) ──
# Controls step budget, tool-call limit, and error tolerance.
# See docs/theory/operating-modes.md for details.
# AGENT_OPERATING_MODE=standard

# ── Agent model router ──
# AGENT_MODEL_ROUTER_MODEL=phi4-mini:latest

# ── Qdrant (vector database for semantic memory) ──
QDRANT_PORT=6333
QDRANT_URL=http://localhost:6333

# ── Tool: image_classify (vision) ──
TOOL_VISION_MODEL=llava:13b
TOOL_VISION_TEMPERATURE=0.2
TOOL_VISION_TOP_P=0.8
TOOL_VISION_TOP_K=20
TOOL_VISION_NUM_CTX=4096
TOOL_VISION_REPEAT_PENALTY=1.3

# ── Tools: image_sketch / image_colorize (external image processor) ──
IMAGE_PROCESSOR_URL=http://localhost:5000
IMAGE_PROCESSOR_TIMEOUT=120000

# ── Tool: code_autocomplete (IDE) ──
TOOL_IDE_MODEL=starcoder2:15b
TOOL_IDE_TEMPERATURE=0.1
TOOL_IDE_TOP_P=0.7
TOOL_IDE_TOP_K=10
TOOL_IDE_NUM_CTX=8192
TOOL_IDE_REPEAT_PENALTY=1.2

# ── Tool: speech_to_text ──
TOOL_STT_MODEL=whisper

# ── Vision feedback loop ──
AGENT_MULTIMODAL_MODELS=llava,bakllava,qwen2-vl,gemma3

# ── Tool: mysql_query ──
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=

# ── Tool: pg_query ──
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=postgres
# PG_PASSWORD=
# PG_DATABASE=

# ── Tool: mongo_query ──
# MONGO_URI=mongodb://localhost:27017
# MONGO_DATABASE=

# ── Persistence (internal PostgreSQL — agent/swarm/eval run storage) ──
# Set MANNA_DB_ENABLED=false to disable persistence (agent still runs fine).
MANNA_DB_HOST=localhost
MANNA_DB_PORT=5432
MANNA_DB_USER=manna
MANNA_DB_PASSWORD=manna
MANNA_DB_NAME=manna
# MANNA_DB_ENABLED=true

# ── Knowledge graph (Neo4j) ──
# If Neo4j is not running, the graph tools fail open and never crash the agent.
NEO4J_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=put-your-password-here
# NEO4J_DATABASE=neo4j

# Model used for entity/relationship extraction (NER).
# Defaults to AGENT_MODEL_FAST if unset.
# GRAPH_NER_MODEL=llama3.1:8b

# ── API CORS ──
CORS_ORIGIN=*

# ── API container port (docker-compose) ──
MANNA_PORT=3001

# ── i18n ──
MANNA_DEFAULT_LOCALE=en
MANNA_FALLBACK_LOCALE=en

# ── Nodemailer (opt-in — only active when SMTP_HOST is set) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER=
SMTP_SECURE=false

# ── Swarm / LangGraph orchestrator ──
# SWARM_MAX_REVIEW_RETRIES=1
