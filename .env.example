# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for the Podman / Docker Compose stack.
#
# Instructions:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in the values below (especially WEBUI_SECRET_KEY)
#   3. NEVER commit the resulting .env file — it is already in .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# Your Linux username (used to mount the shared ~/.ollama model cache)
LINUX_USERNAME=your-linux-username

# Secret key for the Open WebUI session.  Change this before first run!
WEBUI_SECRET_KEY=change-me-in-production

# Set to "false" to disable new account sign-ups after initial setup
ENABLE_SIGNUP=true

# ── Ollama runtime constraints ──
# Force only ONE model loaded at a time — critical for 24 GB VRAM (RTX 4090)
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=1

# ── Tool: image_classify (vision) ──
TOOL_VISION_MODEL=llava:13b-v1.6-vicuna-q4_K_M
TOOL_VISION_TEMPERATURE=0.2
TOOL_VISION_TOP_P=0.8
TOOL_VISION_TOP_K=20
TOOL_VISION_NUM_CTX=4096
TOOL_VISION_REPEAT_PENALTY=1.3

# ── Tool: code_autocomplete (IDE) ──
TOOL_IDE_MODEL=qwen2.5-coder:7b-instruct-q8_0
TOOL_IDE_TEMPERATURE=0.1
TOOL_IDE_TOP_P=0.7
TOOL_IDE_TOP_K=10
TOOL_IDE_NUM_CTX=8192
TOOL_IDE_REPEAT_PENALTY=1.2

# ── Tool: speech_to_text ──
TOOL_STT_MODEL=whisper

# ── Tool: semantic_search + memory ──
OLLAMA_EMBED_MODEL=nomic-embed-text

# ── Agent profile: fast ──
AGENT_MODEL_FAST=llama3.1:8b-instruct-q8_0
AGENT_MODEL_FAST_TEMPERATURE=0.3
AGENT_MODEL_FAST_TOP_P=0.85
AGENT_MODEL_FAST_TOP_K=30
AGENT_MODEL_FAST_NUM_CTX=4096
AGENT_MODEL_FAST_REPEAT_PENALTY=1.2

# ── Agent profile: code ──
AGENT_MODEL_CODE=qwen2.5-coder:14b-instruct-q8_0
AGENT_MODEL_CODE_TEMPERATURE=0.2
AGENT_MODEL_CODE_TOP_P=0.8
AGENT_MODEL_CODE_TOP_K=20
AGENT_MODEL_CODE_NUM_CTX=8192
AGENT_MODEL_CODE_REPEAT_PENALTY=1.3

# ── Agent profile: reasoning ──
AGENT_MODEL_REASONING=deepseek-r1:32b-qwen-distill-q4_K_M
AGENT_MODEL_REASONING_TEMPERATURE=0.2
AGENT_MODEL_REASONING_TOP_P=0.8
AGENT_MODEL_REASONING_TOP_K=20
AGENT_MODEL_REASONING_NUM_CTX=8192
AGENT_MODEL_REASONING_REPEAT_PENALTY=1.3

# ── Agent profile: default ──
AGENT_MODEL_DEFAULT=llama3.1:8b-instruct-q8_0
AGENT_MODEL_DEFAULT_TEMPERATURE=0.3
AGENT_MODEL_DEFAULT_TOP_P=0.85
AGENT_MODEL_DEFAULT_TOP_K=30
AGENT_MODEL_DEFAULT_NUM_CTX=8192
AGENT_MODEL_DEFAULT_REPEAT_PENALTY=1.2

# ── Agent router ──
AGENT_MODEL_ROUTER_MODE=rules
AGENT_MODEL_ROUTER_MODEL=phi4-mini:latest
