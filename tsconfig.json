{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "node",
        "ignoreDeprecations": "5.0",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "rootDir": ".",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true
    },
    "include": ["apps/**/*.ts", "packages/**/*.ts"],
    "exclude": ["node_modules", "dist"]
}
