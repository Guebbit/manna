# Dependencies
node_modules/

# Build output
dist/
/api/*
!/api/apis/
!/api/apis/**
!/api/models/
!/api/models/**
!/api/index.ts
!/api/runtime.ts

# Environment variables — never commit secrets
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*

# OS artefacts
.DS_Store
Thumbs.db

# Playwright browser downloads
/packages/tools/node_modules/

# Data directory contents (keep the folder, ignore actual data files)
data/*
!data/.gitkeep
!data/diagnostics/
!data/diagnostics/.gitkeep
# Diagnostic log files written by the agent (test or production runs)
data/diagnostics/*.md

.idea
docs/.vitepress/cache/
docs/.vitepress/dist/
